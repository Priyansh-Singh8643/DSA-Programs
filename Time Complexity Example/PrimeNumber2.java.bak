import java.util.Scanner;

class PrimeNumber2 
{
	public static void main(String[] args) 
	{
		Scanner sc=new Scanner(System.in);
		
		System.out.print("Enter Number : ");
		int n=sc.nextInt();
		
		for (int i=2;i*i<n;i++)
		{
			if(n%i==0)
			{
				prime=1;
				break;
			}
		}
		
		if(prime==1)
		{
			System.out.println("Number is not Prime ");
		}else{
			System.out.println("Number is Prime");
		}
	}
}
